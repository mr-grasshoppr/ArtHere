// Art Here Portland — Prisma schema
// Vercel Postgres (via DATABASE_URL connection string)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth / Auth.js) ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Artists ─────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  artist    Artist?
}

model Artist {
  id               String           @id @default(cuid())
  userId           String           @unique
  slug             String           @unique
  name             String
  bio              String?          @db.Text
  bioPhotoUrl      String?
  heroImageUrl     String?
  website          String?
  instagram        String?
  commissionStatus CommissionStatus @default(UNSPECIFIED)
  priceRangeMin    Int?
  priceRangeMax    Int?
  sizeRangeMin     Int?
  sizeRangeMax     Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  artworkImages    ArtworkImage[]
  placeRelations   ArtistPlace[]
  intake           ArtistIntake?
}

enum CommissionStatus {
  OPEN
  CLOSED
  ON_REQUEST
  UNSPECIFIED
}

// ─── Artwork Images ───────────────────────────────────────────────────────────

model ArtworkImage {
  id         String    @id @default(cuid())
  artistId   String
  url        String
  altText    String?
  sortOrder  Int       @default(0)
  isHero     Boolean   @default(false)
  uploadedAt DateTime  @default(now())

  // AI-generated tags stored as JSON
  // Shape: { medium, colors, scale, style, subjects, indoor_outdoor, mood }
  aiTags     Json?
  aiTaggedAt DateTime?

  artist     Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// ─── Places ───────────────────────────────────────────────────────────────────

model Place {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  neighborhood String?
  description  String?       @db.Text
  website      String?
  heroImageUrl String?
  createdAt    DateTime      @default(now())

  artists      ArtistPlace[]
}

model ArtistPlace {
  id           String            @id @default(cuid())
  artistId     String
  placeId      String
  relationship PlaceRelationship
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime          @default(now())

  artist       Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  place        Place             @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([artistId, placeId, relationship])
}

enum PlaceRelationship {
  INSTRUCTOR
  STUDENT
  GRANTEE
  EXHIBITING_ARTIST
  MEMBER
}

// ─── Artist Intake (structured data for search) ───────────────────────────────

model ArtistIntake {
  id                   String   @id @default(cuid())
  artistId             String   @unique
  commissionTypes      String[]
  turnaroundWeeks      Int?
  shipsInternationally Boolean  @default(false)
  worksInPerson        Boolean  @default(false)
  notes                String?  @db.Text
  updatedAt            DateTime @updatedAt

  artist               Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

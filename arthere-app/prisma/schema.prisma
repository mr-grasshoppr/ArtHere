// Art Here Portland — Prisma schema
// Vercel Postgres (via DATABASE_URL connection string)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth / Auth.js) ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users & Artists ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  artist    Artist?
}

model Artist {
  id               String           @id @default(cuid())
  userId           String           @unique
  slug             String           @unique
  name             String
  bio              String?          @db.Text
  bioPhotoUrl      String?
  heroImageUrl     String?
  website          String?
  instagram        String?
  medium           String?
  neighborhood     String?
  commissionStatus CommissionStatus @default(UNSPECIFIED)
  priceRangeMin    Int?
  priceRangeMax    Int?
  sizeRangeMin     Int?
  sizeRangeMax     Int?
  hireFor          String?          @db.Text
  hireTags         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  cityId           String?
  city             City?            @relation(fields: [cityId], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  artworkImages    ArtworkImage[]
  placeRelations   ArtistPlace[]
  intake           ArtistIntake?
  adminNotes       AdminNote[]
  magicLinkTokens  MagicLinkToken[]
}

enum CommissionStatus {
  OPEN
  CLOSED
  ON_REQUEST
  UNSPECIFIED
}

// ─── Artwork Images ───────────────────────────────────────────────────────────

model ArtworkImage {
  id         String    @id @default(cuid())
  artistId   String
  url        String
  altText    String?
  sortOrder  Int       @default(0)
  isHero     Boolean   @default(false)
  uploadedAt DateTime  @default(now())

  // AI-generated tags stored as JSON
  // Shape: { medium, colors, scale, style, subjects, indoor_outdoor, mood }
  aiTags     Json?
  aiTaggedAt DateTime?

  artist     Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// ─── Places ───────────────────────────────────────────────────────────────────

model Place {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  neighborhood String?
  description  String?       @db.Text
  website      String?
  heroImageUrl String?
  // A few extra photos shown in a gallery on the place's page.
  galleryImages String[]     @default([])
  // Whether this place appears in the city Community directory page.
  // Places an artist is connected to but that aren't part of the curated
  // directory (closed venues, schools, etc.) are still listed on the
  // artist's profile, just not linked or shown on the Community page.
  inDirectory  Boolean       @default(true)
  createdAt    DateTime      @default(now())

  artists      ArtistPlace[]
}

model ArtistPlace {
  id           String            @id @default(cuid())
  artistId     String
  placeId      String
  relationship PlaceRelationship
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime          @default(now())

  artist       Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  place        Place             @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([artistId, placeId, relationship])
}

enum PlaceRelationship {
  INSTRUCTOR
  STUDENT
  GRANTEE
  EXHIBITING_ARTIST
  MEMBER
  IN_SHOP
}

// ─── Artist Intake (structured data for search) ───────────────────────────────

model ArtistIntake {
  id                   String   @id @default(cuid())
  artistId             String   @unique
  commissionTypes      String[]
  turnaroundWeeks      Int?
  shipsInternationally Boolean  @default(false)
  worksInPerson        Boolean  @default(false)
  notes                String?  @db.Text
  updatedAt            DateTime @updatedAt

  artist               Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// ─── Cities ───────────────────────────────────────────────────────────────────

model City {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  state               String?
  displayName         String?
  logoOverlayImageUrl String?
  description         String?  @db.Text
  createdAt           DateTime @default(now())

  artists             Artist[]
}

// ─── Community Survey ─────────────────────────────────────────────────────────
// Responses to the "Portland Community Survey" (/survey). Free-text answers
// are nullable since most questions are optional / conditionally shown.

model SurveyResponse {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // About Portland
  portlandFamiliarity  String? // Q1
  portlandWords        String[] @default([]) // Q2 — three words
  portlandHelpers      String?  @db.Text // Q3
  portlandSupport      String[] @default([]) // How would you like to support the artist community in Portland?
  portlandSupportOther String? // Write-in for "Other" in portlandSupport
  portlandWish         String?  @db.Text // Q4 — "magic wand" change

  // About You
  occupation        String[] @default([])
  occupationOther   String?
  artistStatus      String?
  artistStatusOther String?
  ageRange          String?

  // Where are you based
  zipCode       String? // Q6
  neighborhoods String?  @db.Text // Q7

  // About Multnomah Village
  mvFamiliarity    String? // Q8
  mvWords          String[] @default([]) // Q9 — three words (deprecated, kept for old responses)
  mvConnectionLevel String? // How connected do you feel to the artist community in MV?
  mvHelpers        String?  @db.Text // What people/places helped you discover artists in MV?
  mvSupport        String[] @default([]) // How would you most like to connect with/support artists in MV?
  mvSupportOther   String? // Write-in for "Other" in mvSupport

  // Multnomah Days 2026 (deprecated — kept for old responses)
  multnomahDaysInvolvement String[] @default([])

  // About Your Practice
  practiceActivities String[] @default([]) // Q12
  practiceGoals      String[] @default([]) // Q13 — up to three
  practiceGoalsOther String? // Q13 "Other" free text
  practiceSupport    String?  @db.Text // Q14

  // Become a Featured Artist (deprecated — kept for old responses)
  featuredArtistInterest String?

  // Stay in Touch (deprecated — kept for old responses)
  stayConnected String[] @default([])

  // Get Involved (replaces featured artist + stay connected + multnomah days)
  involvementInterests      String[] @default([])
  involvementInterestsOther String?

  // Raffle + Email
  raffleOptIn String?
  email       String?

  // Referral
  learnedAbout String[] @default([])
}

// ─── Magic Link Tokens ────────────────────────────────────────────────────────
// One-time links sent to featured-artist opt-ins after survey completion.
// A token is single-use and expires after 72 hours.

model MagicLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  email     String
  artistId  String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// ─── Admin Notes ──────────────────────────────────────────────────────────────

model AdminNote {
  id        String   @id @default(cuid())
  artistId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}
